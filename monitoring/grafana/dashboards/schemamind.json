  "panels": [
    {
      "type": "row",
      "title": "RAG",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "id": 100,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Retrieval duration (p50 / p95 / p99)",
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(rag_retrieval_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rag_retrieval_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(rag_retrieval_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Retrievals / sec",
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}
      },
      "options": {
        "legend": {"showLegend": false},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "expr": "rate(rag_retrievals_total[5m])",
          "legendFormat": "retrievals/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Seed vs total tables (p95)",
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rag_seed_tables_bucket[5m])))",
          "legendFormat": "seed tables p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rag_total_tables_bucket[5m])))",
          "legendFormat": "total tables (after expansion) p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total retrievals",
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "expr": "sum(rag_retrievals_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Agent (LLM)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17},
