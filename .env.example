# Required: long random string for JWT signing
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Optional: your Google AI Studio key
# Can also be set per-user via POST /api/settings/api-key after login
GOOGLE_API_KEY=

# Optional: host port mapping (default 8000)
APP_PORT=8000

# Optional: monitoring ports
FRONTEND_PORT=8080
PROMETHEUS_PORT=9091
GRAFANA_PORT=3000
NODE_EXPORTER_PORT=9100

# Optional: Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
